generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ResidentType {
  OWNER_OCCUPIER
  DIRECT_TENANT
  MANAGED_TENANT
  ABSENTEE_OWNER
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

model User {
  id        Int      @id @default(autoincrement()) 
  fullName  String?
  email     String   @unique
  password  String   // Use String here (bcrypt will hash this)
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Estate {
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  units     Unit[]
  
  createdAt DateTime @default(now())
}



model Unit {
  id             Int        @id @default(autoincrement())
  estateId       Int
  estate         Estate     @relation(fields: [estateId], references: [id])
  unitNumber     String
  monthlyCharge  Decimal    @db.Decimal(10, 2)
  residents      Resident[]
  invoices       Invoice[]
}

model Resident {
  id           Int           @id @default(autoincrement())
  unitId       Int
  unit         Unit          @relation(fields: [unitId], references: [id])
  fullName    String     
  email        String        @unique
  phone        String?      
  type         ResidentType
  moveInDate   DateTime
  isActive     Boolean       @default(true)
  invoices     Invoice[]
  logs         CommunicationLog[]
  createdAt    DateTime      @default(now())
}



model Invoice {
  id           Int           @id @default(autoincrement())
  residentId   Int
  resident     Resident      @relation(fields: [residentId], references: [id])
  unitId       Int
  unit         Unit          @relation(fields: [unitId], references: [id])
  invoiceDate  DateTime      @default(now())
  dueDate      DateTime
  amount       Decimal       @db.Decimal(10, 2)
  lateFee      Decimal       @default(0) @db.Decimal(10, 2)
  status       InvoiceStatus @default(PENDING)
  payments     Payment[]
  referenceNo   String        @unique
billingMonth  Int
billingYear   Int
daysOverdue   Int           @default(0)

@@unique([residentId, billingMonth, billingYear])
}

model Payment {
  id           Int      @id @default(autoincrement())
  invoiceId    Int
  invoice      Invoice  @relation(fields: [invoiceId], references: [id])
  paymentDate  DateTime @default(now())
  amountPaid   Decimal  @db.Decimal(10, 2)
  method       String
  receiptNo    String   @unique
  notes       String?
}

model CommunicationLog {
  id           Int      @id @default(autoincrement())
  residentId   Int
  resident     Resident @relation(fields: [residentId], references: [id])
  sentAt       DateTime @default(now())
  type         String
  channel      String
  content      String
  sentBy       String
  followUp   Boolean  @default(false)
}